# 7. pyproject.toml dependency group 案

uv は dependency groups に group-level `requires-python` を設定できます。重い crypto / nautilus / hft group は dev default に混ぜない方がよいです。([Astral Docs][16])

```toml
[project]
requires-python = ">=3.12,<3.15"
dependencies = [
  "pydantic>=2.10",
  "pydantic-settings>=2.6",
  "typer>=0.15",
  "rich>=13.9",
]

[dependency-groups]
dev = [
  "ruff",
  "mypy",
  "pytest",
  "pytest-cov",
  "hypothesis",
]

data = [
  "numpy",
  "pandas>=2.2,<3.0",
  "polars",
  "duckdb",
  "pyarrow",
  "pandera[polars]",
]

crypto-data = [
  { include-group = "data" },
  "ccxt",
  "orjson",
  "aiohttp",
  "websockets",
]

research = [
  { include-group = "crypto-data" },
  "scipy",
  "scikit-learn",
  "statsmodels",
  "cvxpy",
  "optuna",
  "mlflow",
]

screening = [
  { include-group = "research" },
  "numba",
]

screening-vectorbt = [
  { include-group = "screening" },
  "vectorbt",
]

